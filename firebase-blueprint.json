{
  "entities": {
    "SalaryRecord": {
      "title": "SalaryRecord",
      "description": "A record of monthly salary income and deductions",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner" },
        "date": { "type": "string", "description": "Year and month (YYYY-MM)" },
        "rank": { "type": "string", "description": "Rank/Grade" },
        "salaryPoint": { "type": "number", "description": "Salary points" },
        "basicPay": { "type": "number", "description": "Basic pay" },
        "professionalAllowance": { "type": "number", "description": "Professional allowance" },
        "medicalIncentive": { "type": "number", "description": "Medical incentive" },
        "yearEndBonus": { "type": "number", "description": "Year-end bonus" },
        "performanceBonus": { "type": "number", "description": "Performance bonus" },
        "overtimePay": { "type": "number", "description": "Overtime pay" },
        "otherIncome": { "type": "number", "description": "Other income" },
        "retroactivePay": { "type": "number", "description": "Retroactive pay" },
        "civilServiceInsurance": { "type": "number", "description": "Civil service insurance" },
        "healthInsurance": { "type": "number", "description": "Health insurance" },
        "pensionFund": { "type": "number", "description": "Pension fund" },
        "otherDeduction": { "type": "number", "description": "Other deduction" },
        "taxableIncome": { "type": "number", "description": "Taxable income" },
        "note": { "type": "string", "description": "Optional note" }
      },
      "required": ["uid", "date", "basicPay"]
    },
    "CreditCard": {
      "title": "CreditCard",
      "description": "Credit card information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner" },
        "name": { "type": "string", "description": "Card name" },
        "bank": { "type": "string", "description": "Issuing bank" },
        "statementDate": { "type": "number", "description": "Statement day of month" },
        "dueDate": { "type": "number", "description": "Due day of month" },
        "limit": { "type": "number", "description": "Credit limit" },
        "currentBalance": { "type": "number", "description": "Current balance" }
      },
      "required": ["uid", "name", "bank"]
    },
    "BankAccount": {
      "title": "BankAccount",
      "description": "Bank account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner" },
        "name": { "type": "string", "description": "Account name" },
        "bankName": { "type": "string", "description": "Bank name" },
        "balance": { "type": "number", "description": "Current balance" },
        "type": { "type": "string", "enum": ["savings", "checking", "fixed"], "description": "Account type" }
      },
      "required": ["uid", "name", "bankName", "balance", "type"]
    },
    "Fund": {
      "title": "Fund",
      "description": "Investment fund information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner" },
        "name": { "type": "string", "description": "Fund name" },
        "cost": { "type": "number", "description": "Total cost" },
        "currentValue": { "type": "number", "description": "Current market value" },
        "units": { "type": "number", "description": "Number of units" }
      },
      "required": ["uid", "name", "cost", "currentValue", "units"]
    },
    "Stock": {
      "title": "Stock",
      "description": "Stock investment information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner" },
        "symbol": { "type": "string", "description": "Stock symbol" },
        "name": { "type": "string", "description": "Stock name" },
        "shares": { "type": "number", "description": "Number of shares" },
        "averageCost": { "type": "number", "description": "Average cost per share" },
        "currentPrice": { "type": "number", "description": "Current market price" }
      },
      "required": ["uid", "symbol", "name", "shares", "averageCost", "currentPrice"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Yearly budget allocation with frequency and status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner" },
        "category": { "type": "string", "description": "Budget category" },
        "allocated": { "type": "number", "description": "Allocated amount" },
        "spent": { "type": "number", "description": "Spent amount" },
        "year": { "type": "number", "description": "Year" },
        "frequency": { "type": "string", "enum": ["monthly", "quarterly", "semi-annually", "annually"], "description": "Frequency of the expense" },
        "isPaid": { "type": "boolean", "description": "Whether the budget has been fully spent/paid" }
      },
      "required": ["uid", "category", "allocated", "spent", "year", "frequency", "isPaid"]
    },
    "YearlyStandard": {
      "title": "YearlyStandard",
      "description": "Standard expected salary values for a specific year",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner" },
        "year": { "type": "string", "description": "The year (YYYY)" },
        "basicPay": { "type": "number", "description": "Expected basic pay for this year" },
        "professionalAllowance": { "type": "number", "description": "Expected professional allowance for this year" }
      },
      "required": ["uid", "year", "basicPay", "professionalAllowance"]
    },
    "TaxRecord": {
      "title": "TaxRecord",
      "description": "A detailed record of annual income tax filings and calculations",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner" },
        "year": { "type": "number", "description": "Tax year (ROC)" },
        "salaryUser": { "type": "number", "description": "Salary income of the user" },
        "salarySpouse": { "type": "number", "description": "Salary income of the spouse" },
        "profitIncome": { "type": "number", "description": "Profit income (including 54C dividends)" },
        "interestIncome": { "type": "number", "description": "Interest income" },
        "exemptionsCount": { "type": "number", "description": "Count of normal exemptions (taxpayer, spouse, dependents < 70)" },
        "exemptionsSeniorCount": { "type": "number", "description": "Count of senior exemptions (dependents >= 70)" },
        "isMarried": { "type": "boolean", "description": "Whether the filing is for a married couple" },
        "propertyLossDeduction": { "type": "number", "description": "Property transaction loss deduction" },
        "savingsDeduction": { "type": "number", "description": "Savings and investment special deduction" },
        "disabilityCount": { "type": "number", "description": "Count of individuals for disability deduction" },
        "educationCount": { "type": "number", "description": "Count of individuals for education tuition deduction" },
        "preschoolCount": { "type": "number", "description": "Count of individuals for preschool deduction" },
        "longTermCareCount": { "type": "number", "description": "Count of individuals for long-term care deduction" },
        "startupInvestmentDeduction": { "type": "number", "description": "Investment in startup companies deduction" },
        "investmentCredits": { "type": "number", "description": "Investment tax credits" },
        "homePurchaseCredits": { "type": "number", "description": "Home purchase tax credits" },
        "withholding": { "type": "number", "description": "Total withholding tax" },
        "dividendCredits": { "type": "number", "description": "Dividend tax credits (8.5% capped at 80k)" },
        "mainlandTaxCredits": { "type": "number", "description": "Tax credits for income from Mainland China" },
        "note": { "type": "string", "description": "Optional note" }
      },
      "required": ["uid", "year"]
    },
    "TaxStandard": {
      "title": "TaxStandard",
      "description": "Yearly tax deduction and exemption standards and brackets",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the owner" },
        "year": { "type": "number", "description": "ROC year (e.g., 112)" },
        "exemptionBase": { "type": "number", "description": "Base exemption per person" },
        "exemptionSenior": { "type": "number", "description": "Senior exemption per person (70+)" },
        "standardDeductionSingle": { "type": "number", "description": "Standard deduction for single filers" },
        "standardDeductionMarried": { "type": "number", "description": "Standard deduction for married filers" },
        "salaryDeductionUnit": { "type": "number", "description": "Special deduction for salary income" },
        "savingsDeductionLimit": { "type": "number", "description": "Maximum savings special deduction" },
        "disabilityDeductionUnit": { "type": "number", "description": "Unit for disability special deduction" },
        "educationDeductionUnit": { "type": "number", "description": "Unit for education tuition deduction" },
        "preschoolDeductionUnit": { "type": "number", "description": "Unit for preschool deduction" },
        "longTermCareDeductionUnit": { "type": "number", "description": "Unit for long-term care deduction" },
        "basicLivingExpenseUnit": { "type": "number", "description": "Basic living expense per person" },
        "taxBrackets": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "limit": { "type": "number", "description": "Upper limit of the bracket taxable income" },
              "rate": { "type": "number", "description": "Tax rate for this bracket (decimal)" },
              "adjustment": { "type": "number", "description": "Progressive difference (adjustment amount)" }
            }
          }
        }
      },
      "required": ["uid", "year"]
    }
  },
  "firestore": {
    "/salaryRecords/{recordId}": {
      "schema": "SalaryRecord",
      "description": "Collection of salary records"
    },
    "/yearlyStandards/{standardId}": {
      "schema": "YearlyStandard",
      "description": "Collection of yearly salary standards"
    },
    "/creditCards/{cardId}": {
      "schema": "CreditCard",
      "description": "Collection of credit cards"
    },
    "/bankAccounts/{accountId}": {
      "schema": "BankAccount",
      "description": "Collection of bank accounts"
    },
    "/funds/{fundId}": {
      "schema": "Fund",
      "description": "Collection of investment funds"
    },
    "/stocks/{stockId}": {
      "schema": "Stock",
      "description": "Collection of stocks"
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Collection of budgets"
    },
    "/taxes/{taxId}": {
      "schema": "TaxRecord",
      "description": "Collection of income tax records"
    },
    "/taxStandards/{standardId}": {
      "schema": "TaxStandard",
      "description": "Collection of yearly tax standards"
    }
  }
}
