rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return (isSignedIn() && request.auth.uid == uid) || uid == 'default-user' || uid == 'local_default_user';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function canAccessData(data) {
      return data.uid == 'default-user' || 
             data.uid == 'local_default_user' || 
             data.uid == 'guest-user' || 
             data.uid == 'guest' || 
             data.uid == 'anonymous' || 
             data.uid == 'local_user' ||
             data.uid == 'jason2134@gmail.com' ||
             (isSignedIn() && (data.uid == request.auth.uid || data.uid == request.auth.token.email));
    }

    match /test/connection {
      allow read: if true;
    }

    // --- Entity Validators ---
    function isValidSalaryRecord(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.date is string &&
             data.date.size() <= 10 &&
             data.basicPay is number;
    }

    function isValidYearlyStandard(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.year is string &&
             data.year.size() <= 4 &&
             data.basicPay is number &&
             data.professionalAllowance is number;
    }

    function isValidCreditCard(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.bank is string &&
             data.bank.size() <= 100;
    }

    function isValidBankAccount(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.bankName is string &&
             data.bankName.size() <= 100 &&
             data.balance is number &&
             data.type is string;
    }

    function isValidFund(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.cost is number &&
             data.currentValue is number &&
             data.units is number;
    }

    function isValidStock(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.symbol is string &&
             data.symbol.size() <= 20 &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.shares is number &&
             data.averageCost is number &&
             data.currentPrice is number;
    }

    function isValidBudget(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.category is string &&
             data.category.size() <= 50 &&
             data.allocated is number &&
             data.spent is number &&
             data.year is number;
    }

    function isValidTaxRecord(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.year is number;
    }

    function isValidTaxStandard(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.year is number;
    }

    // --- Collection matching ---

    match /salaryRecords/{recordId} {
      allow read, list: if canAccessData(resource.data);
      allow create: if isValidSalaryRecord(incoming());
      allow update: if canAccessData(resource.data) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidSalaryRecord(incoming());
      allow delete: if canAccessData(resource.data);
    }

    match /creditCards/{cardId} {
      allow read, list: if canAccessData(resource.data);
      allow create: if isValidCreditCard(incoming());
      allow update: if canAccessData(resource.data) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidCreditCard(incoming());
      allow delete: if canAccessData(resource.data);
    }

    match /bankAccounts/{accountId} {
      allow read, list: if canAccessData(resource.data);
      allow create: if isValidBankAccount(incoming());
      allow update: if canAccessData(resource.data) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidBankAccount(incoming());
      allow delete: if canAccessData(resource.data);
    }

    match /funds/{fundId} {
      allow read, list: if canAccessData(resource.data);
      allow create: if isValidFund(incoming());
      allow update: if canAccessData(resource.data) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidFund(incoming());
      allow delete: if canAccessData(resource.data);
    }

    match /stocks/{stockId} {
      allow read, list: if canAccessData(resource.data);
      allow create: if isValidStock(incoming());
      allow update: if canAccessData(resource.data) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidStock(incoming());
      allow delete: if canAccessData(resource.data);
    }

    match /budgets/{budgetId} {
      allow read, list: if canAccessData(resource.data);
      allow create: if isValidBudget(incoming());
      allow update: if canAccessData(resource.data) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidBudget(incoming());
      allow delete: if canAccessData(resource.data);
    }

    match /yearlyStandards/{standardId} {
      allow read, list: if canAccessData(resource.data);
      allow create: if isValidYearlyStandard(incoming());
      allow update: if canAccessData(resource.data) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidYearlyStandard(incoming());
      allow delete: if canAccessData(resource.data);
    }

    match /taxes/{taxId} {
      allow read, list: if canAccessData(resource.data);
      allow create: if isValidTaxRecord(incoming());
      allow update: if canAccessData(resource.data) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidTaxRecord(incoming());
      allow delete: if canAccessData(resource.data);
    }

    match /taxStandards/{standardId} {
      allow read, list: if canAccessData(resource.data);
      allow create: if isValidTaxStandard(incoming());
      allow update: if canAccessData(resource.data) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidTaxStandard(incoming());
      allow delete: if canAccessData(resource.data);
    }
  }
}
