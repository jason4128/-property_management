rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return (isSignedIn() && request.auth.uid == uid) || uid == 'default-user' || uid == 'local_default_user';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function canAccessData(data) {
      return !('uid' in data) || 
             data.uid == 'default-user' || 
             data.uid == 'local_default_user' || 
             data.uid == 'guest-user' || 
             data.uid == 'guest' || 
             data.uid == 'anonymous' || 
             data.uid == 'local_user' ||
             data.uid == 'jason2134@gmail.com' ||
             data.uid == 'guest@example.com' ||
             (isSignedIn() && (
               data.uid == request.auth.uid || 
               data.uid == request.auth.token.email ||
               request.auth.token.email == 'jason2134@gmail.com'
             ));
    }

    match /test/connection {
      allow read: if true;
    }

    // --- Entity Validators ---
    function isValidSalaryRecord(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.date is string &&
             data.date.size() <= 10 &&
             data.basicPay is number;
    }

    function isValidYearlyStandard(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.year is string &&
             data.year.size() <= 4 &&
             data.basicPay is number &&
             data.professionalAllowance is number;
    }

    function isValidCreditCard(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.bank is string &&
             data.bank.size() <= 100 &&
             data.statementDate is number &&
             data.dueDate is number;
    }

    function isValidCreditCardBill(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.cardId is string &&
             data.month is string &&
             data.amount is number;
    }

    function isValidInsurance(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.name is string &&
             data.name.size() <= 200;
    }

    function isValidInsurancePremium(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.insuranceId is string &&
             data.age is number &&
             data.premium is number;
    }

    function isValidBankAccount(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.bankName is string &&
             data.bankName.size() <= 100 &&
             data.balance is number &&
             data.type is string;
    }

    function isValidFund(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.cost is number &&
             data.currentValue is number &&
             data.units is number;
    }

    function isValidStock(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.symbol is string &&
             data.symbol.size() <= 20 &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.shares is number &&
             data.averageCost is number &&
             data.currentPrice is number;
    }

    function isValidBudget(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.category is string &&
             data.category.size() <= 50 &&
             data.allocated is number &&
             data.spent is number &&
             data.year is number;
    }

    function isValidTaxRecord(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.year is number;
    }

    function isValidTaxStandard(data) {
      return data.uid is string &&
             canAccessData(data) &&
             data.year is number;
    }

    // --- Collection matching ---

    match /salaryRecords/{recordId} {
      allow read: if true;
      allow create: if isValidSalaryRecord(incoming()) && isValidId(recordId);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidSalaryRecord(incoming()) && isValidId(recordId);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /creditCards/{cardId} {
      allow read: if true;
      allow create: if isValidCreditCard(incoming()) && isValidId(cardId);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidCreditCard(incoming()) && isValidId(cardId);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /creditCardBills/{billId} {
      allow read: if true;
      allow create: if isValidCreditCardBill(incoming()) && isValidId(billId);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidCreditCardBill(incoming()) && isValidId(billId);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /insurances/{id} {
      allow read: if true;
      allow create: if isValidInsurance(incoming()) && isValidId(id);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidInsurance(incoming()) && isValidId(id);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /insurancePremiums/{id} {
      allow read: if true;
      allow create: if isValidInsurancePremium(incoming()) && isValidId(id);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidInsurancePremium(incoming()) && isValidId(id);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /bankAccounts/{accountId} {
      allow read: if true;
      allow create: if isValidBankAccount(incoming()) && isValidId(accountId);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidBankAccount(incoming()) && isValidId(accountId);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /funds/{fundId} {
      allow read: if true;
      allow create: if isValidFund(incoming()) && isValidId(fundId);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidFund(incoming()) && isValidId(fundId);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /stocks/{stockId} {
      allow read: if true;
      allow create: if isValidStock(incoming()) && isValidId(stockId);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidStock(incoming()) && isValidId(stockId);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /budgets/{budgetId} {
      allow read: if true;
      allow create: if isValidBudget(incoming()) && isValidId(budgetId);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidBudget(incoming()) && isValidId(budgetId);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /yearlyStandards/{standardId} {
      allow read: if true;
      allow create: if isValidYearlyStandard(incoming()) && isValidId(standardId);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidYearlyStandard(incoming()) && isValidId(standardId);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /taxes/{taxId} {
      allow read: if true;
      allow create: if isValidTaxRecord(incoming()) && isValidId(taxId);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidTaxRecord(incoming()) && isValidId(taxId);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }

    match /taxStandards/{standardId} {
      allow read: if true;
      allow create: if isValidTaxStandard(incoming()) && isValidId(standardId);
      allow update: if (canAccessData(resource.data) || !('uid' in resource.data)) && (incoming().uid == existing().uid || canAccessData(incoming())) && isValidTaxStandard(incoming()) && isValidId(standardId);
      allow delete: if canAccessData(resource.data) || !('uid' in resource.data);
    }
  }
}
